# Ambiente
NODE_ENV=development
PORT=3333

# Database
# Local/Docker: DATABASE_URL e DIRECT_URL podem ser iguais.
# Supabase/produção: DATABASE_URL usa o pooler (porta 6543), DIRECT_URL a conexão direta (porta 5432), usada para migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/everlabs?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/everlabs?schema=public"

# JWT
JWT_SECRET=sua_chave_secreta_aqui
JWT_EXPIRES_IN=1d

# Upload
UPLOAD_FOLDER=./uploads